Anime {
  Program     = Statement*

  Statement   = PrintStmt
              | LetStmt
              | AssignStmt
              | IfStmt

  PrintStmt   = print "(" Exp ")"
  LetStmt     = let id "=" Exp
  AssignStmt  = Primary_id "=" Exp
  IfStmt      = if Exp "{" Statement* "}"

  Exp         = Condition relop Condition  -- binary
              | Condition

  Condition   = Condition addop Term       -- binary
              | Term

  Term        = Term mulop Factor          -- binary
              | Factor

  Factor      = Primary "**" Factor        -- exponentiation
              | "-" Primary                -- negation
              | Primary

  Primary     = num
              | false
              | true
              | id                         -- id
              | "(" Exp ")"                -- parens

  relop       = "<" | ">" | "<=" | ">=" | "==" | "!="
  addop       = "+" | "-"
  mulop       = "*" | "/" | "%"

  num         = digit+

  let         = "let" ~alnum
  print       = "print" ~alnum
  if          = "if" ~alnum
  false       = "false" ~alnum
  true        = "true" ~alnum
  keyword     = let | print | if | false | true

  id          = ~keyword letter alnum*

  space      += comment
  comment     = "//" (~"\n" any)*
}