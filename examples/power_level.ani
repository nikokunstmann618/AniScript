// Power Level Check — inspired by Dragon Ball Z

nakama power = 9001

kakugo power > 9000 {
  shout("It's over 9000!!!")
} masaka {
  shout("Power level is within limits.")
}

// Count up to a power level
nakama level = 1
shout("Training begins...")

tatakai level <= 5 {
  shout("Level: " + level)
  level = level + 1
}

shout("Training complete! Final level: " + level)
