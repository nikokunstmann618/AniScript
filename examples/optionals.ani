// Defaulting with geass, plus a small "box" move

// "no int"  →  use default 2
jutsu maybeX = 0
jutsu y = 0
geass maybeX == 0 {
  y = 2
} counter {
  y = maybeX
}
creation("y = " + y)

// A simple "box" (like some S(1) / z?.x) — one field, manual unwrap
move Box {
  awaken(v) { this.x = v }
  val() { kaeru this.x }
}

jutsu z = summon Box(1)
jutsu w = z.val()
creation("w = " + w)
